# ============================================================
# 安全 AI Agent - 环境变量配置模板
# 复制为 .env 并填入真实值，严禁提交 .env 至 Git
# ============================================================

# --- LLM 模型 ---
LLM_PROVIDER=openai                          # claude | openai | vllm
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=                             # OpenAI兼容API地址（DeepSeek用 https://api.deepseek.com/v1）
OPENAI_MODEL=gpt-4o                          # DeepSeek 用 deepseek-chat
VLLM_BASE_URL=http://192.168.80.101:8000
VLLM_MODEL=qwen2.5-72b

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=192.168.80.101:9092
KAFKA_TOPIC_RAW_ALERTS=raw-alerts
KAFKA_TOPIC_DLQ=dead-letter-queue
KAFKA_CONSUMER_GROUP=security-agent-group

# --- Milvus ---
MILVUS_HOST=192.168.80.101
MILVUS_PORT=19530
MILVUS_COLLECTION=threat_intel

# --- Neo4j ---
NEO4J_URI=bolt://192.168.80.101:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password_2026

# --- Redis ---
REDIS_URL=redis://:redis_password_2026@192.168.80.101:6379/0
REDIS_CACHE_TTL=3600

# --- Elasticsearch ---
ES_HOSTS=http://192.168.80.101:9200
ES_INDEX_AUDIT=security-agent-audit
ES_INDEX_EVENTS=security-agent-events

# --- 威胁情报 API ---
VIRUSTOTAL_API_KEY=
ALIENVAULT_OTX_API_KEY=

# --- 审批通知 ---
WECHAT_WORK_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=...
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=...

# --- FastAPI ---
API_SECRET_KEY=change-this-secret-key
API_ACCESS_TOKEN_EXPIRE_MINUTES=120
API_REFRESH_TOKEN_EXPIRE_DAYS=7
API_HOST=0.0.0.0
API_PORT=8000

# --- PostgreSQL (主存储: 用户/令牌/审批/主机/主机组/LLM模型/对话) ---
PG_HOST=192.168.80.101
PG_PORT=5432
PG_DATABASE=SecAgent
PG_USER=secagent
PG_PASSWORD=Ke615700
PG_POOL_SIZE=10

# --- Agent / 漏洞扫描子系统 ---
# Console 对外 URL（必须绝对 URL，规则下载 URL 由此拼接；留空则 agent 拿到相对 URL 必然失败）
AGENT_CONSOLE_EXTERNAL_URL=https://192.168.80.101:8000
# TLS（自签证书部署时填）
AGENT_TLS_CERT=
AGENT_TLS_KEY=
AGENT_CA_CERT=
# Ed25519 私钥（64 hex），用于签 WS 敏感命令 + 规则包 body。规则分发链路必配，未配会静默失败。
# 生成: python -c "from cryptography.hazmat.primitives.asymmetric import ed25519; import os; print(os.urandom(32).hex())"
AGENT_SIGNING_KEY=
# 规则包 HMAC-SHA256 密钥（任意串），与 Ed25519 私钥分离。留空回退 AGENT_SIGNING_KEY（向后兼容）。
AGENT_HMAC_KEY=
# Agent 调试日志（true 会打印敏感 payload，生产勿开；对应 Go 端 AGENT_DEBUG=1）
AGENT_DEBUG=false
AGENT_HEARTBEAT_INTERVAL=60
AGENT_BINARY_DIR=deployments/agent/dist
# 规则同步: 默认源 + 定时 cron
RULES_SYNC_SOURCE=nvd                # nvd | github
RULES_SYNC_CRON=0 3 * * *

# --- 规则数据源（联网同步） ---
# NVD API key（提升限速: 匿名 5req/30s -> 带 key 50req/30s）。申请: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=94f7307c-c8a2-4402-808a-9cb42ab9f013
# NVD 代理（国内访问 NVD 超时时配，如 http://192.168.254.121:7897；可直连则留空）
NVD_PROXY=http://192.168.254.121:7897
# GitHub Advisory 同步回看天数（拉取近 N 天的 reviewed advisory，避免全量 28530 条）
ADVISORY_LOOKBACK_DAYS=30

# --- 种子用户密码（生产必须全部设置为 ≥12 位非弱口令，否则启动拒绝；dev_mode=true 放宽并随机生成） ---
DEV_MODE=false
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ANALYST_PASSWORD=
DEFAULT_VIEWER_PASSWORD=
DEFAULT_RESPONDER_PASSWORD=

# --- 沙箱 ---
SANDBOX_CONTAINER_POOL_SIZE=5
SANDBOX_EXEC_TIMEOUT_SEC=60
SANDBOX_NETWORK=sandbox-net

# --- 日志 ---
LOG_LEVEL=INFO
