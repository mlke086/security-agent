# =====================================================================
# SecAgent 生产部署 .env 样例
# 拷贝为 .env 并填入真实值;不要把 .env 提交到 Git。
#
# 这里的变量必须由 env 提供:
#   - PG_PASSWORD / NACOS_PASSWORD:init_schema / Nacos bootstrap
#   - API_SECRET_KEY / AGENT_SIGNING_KEY:JWT 签名 / Ed25519(不能进 Nacos)
#   - AGENT_CONSOLE_EXTERNAL_URL:Agent 端回调地址(主机特定)
# 其余业务配置全部在 Nacos(nacos-config.yaml)。
# =====================================================================

# ============== 必填:引导密钥 ==============

# Postgres 业务库密码(init_schema 启动时立即使用)
PG_PASSWORD=Ke615700

# Nacos 鉴权密码(用于拉取业务配置)
NACOS_PASSWORD=nacos

# JWT 签名密钥(≥16 字符,生产 ≥32)
# 生成: openssl rand -hex 32
API_SECRET_KEY=please-change-me-to-a-32-char-random-string

# Agent Ed25519 私钥(64 hex,用于签名 WS 敏感指令 + 规则包)
# 生成: python -c "from cryptography.hazmat.primitives.asymmetric import ed25519; import os; print(os.urandom(32).hex())"
AGENT_SIGNING_KEY=

# ============== 必填:主机特定值 ==============

# Agent 端的回调 URL(Agent 通过此地址连回服务端)
AGENT_CONSOLE_EXTERNAL_URL=http://192.168.18.156:8000

# ============== 可选:镜像 / 端口 ==============

SECAGENT_IMAGE_API=secagent-api:0.1.0
SECAGENT_IMAGE_FRONTEND=secagent-frontend:0.1.0

# 前端对外端口。**默认 8081**(因为 nginx-reports 经常占用 8080)。
# 改前先用 ss -ltn ":8080" 确认空闲。
FRONTEND_PORT=8081

# ============== 可选:覆盖 Nacos bootstrap(一般不改) ==============

# NACOS_SERVER=http://127.0.0.1:8848
# NACOS_NAMESPACE=prod
# NACOS_GROUP=SECURITY
# NACOS_DATA_ID=security-agent.yaml

# ============== 可选:一次性开关 ==============

# 首次部署时设为 true,后续保持 false(避免每次重启重新推送 Nacos)
RUN_INIT_NACOS=false