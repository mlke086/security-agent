# =====================================================================
# SecAgent 生产部署 .env 样例
# 拷贝为 .env 并填入真实值;不要把 .env 提交到 Git。
# 所有密钥至少 12 位、非弱口令。SECRET_KEY 强制 32+ 位随机。
# =====================================================================

# ---- Postgres(已有)----
PG_PASSWORD=Ke615700
REDIS_PASSWORD=redis_password_2026
NEO4J_PASSWORD=neo4j_password_2026
NACOS_PASSWORD=nacos

# ---- API JWT signing key(强制 32+ 字符)----
# 生成: openssl rand -hex 32
API_SECRET_KEY=please-change-me-to-a-32+-char-random-string

# ---- 镜像 tag(可改成自己仓库的地址)----
SECAGENT_IMAGE_API=secagent-api:0.1.0
SECAGENT_IMAGE_FRONTEND=secagent-frontend:0.1.0

# ---- 前端对外端口 ----
FRONTEND_PORT=8080

# ---- Agent 对外地址(被 Agent 用来回调服务端)----
AGENT_CONSOLE_EXTERNAL_URL=http://192.168.18.156:8000

# ---- Agent Ed25519 签名密钥(64 hex)----
# 生成: python -c "from cryptography.hazmat.primitives.asymmetric import ed25519; import os; print(os.urandom(32).hex())"
AGENT_SIGNING_KEY=

# ---- HMAC(可选,任意字符串)----
AGENT_HMAC_KEY=

# ---- LLM(默认 DeepSeek)----
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# ---- NVD 同步(可选)----
NVD_API_KEY=
NVD_PROXY=http://192.168.254.121:7897
ADVISORY_LOOKBACK_DAYS=30

# ---- 种子用户密码(>=12 位,生产必须改)----
# 留空 + DEV_MODE=false 会启动失败(--strict-password)
DEV_MODE=false
DEFAULT_ADMIN_PASSWORD=Admin@2026-Changeme
DEFAULT_ANALYST_PASSWORD=Analyst@2026-Changeme
DEFAULT_VIEWER_PASSWORD=Viewer@2026-Changeme
DEFAULT_RESPONDER_PASSWORD=Responder@2026-Changeme

# ---- 一次性 init 开关(只在首次部署时为 true)----
RUN_INIT_PG=true
RUN_INIT_NACOS=true
