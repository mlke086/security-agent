            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Mitre Ttps",
            "default": []
          },
          "poc": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Poc"
          },
          "is_vulnerable": {
            "type": "boolean",
            "title": "Is Vulnerable",
            "default": false
          },
          "trace": {
            "items": {
              "$ref": "#/components/schemas/TraceStep"
            },
            "type": "array",
            "title": "Trace",
            "default": []
